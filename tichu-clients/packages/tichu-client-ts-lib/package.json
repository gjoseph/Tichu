{
  "name": "tichu-client-ts-lib",
  "version": "1.0.0",
  "description": "",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "build": "pnpm run clean:some && tsc --build && ava",
    "clean:some": "rm -rf ./lib ./docs",
    "clean:all": "rm -rf ./node_modules ./package-lock.json ./lib ./docs",
    "refresh": "pnpm run clean:all && pnpm install",
    "tscov": "tscov --min-coverage 90",
    "tscov:d": "tscov --details",
    "publish-package": "pnpm run build && pnpm publish",
    "docs": "typedoc --out docs ./src",
    "test": "pnpm run build",
    "lint": "eslint src/"
  },
  "keywords": [],
  "author": "",
  "license": "",
  "engines": {
    "node": "24.16.0",
    "pnpm": "11.5.3"
  },
  "devDependencies": {
    "@ava/typescript": "catalog:",
    "@types/node": "catalog:",
    "@types/ws": "catalog:",
    "ava": "catalog:",
    "typedoc": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@types/fs-extra": "catalog:",
    "fs-extra": "catalog:",
    "nanoid": "catalog:",
    "ts-enum-util": "catalog:",
    "tslib": "catalog:"
  },
  "optionalDependencies": {
    "ws": "catalog:"
  },
  "ava": {
    "typescript": {
      "rewritePaths": {
        "src/": "lib/"
      },
      "compile": false
    }
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended"
    ]
  }
}
