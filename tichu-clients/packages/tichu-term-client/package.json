{
  "name": "tichu-term-client",
  "version": "1.0.0",
  "description": "",
  "main": "./lib/index.js",
  "bin": {
    "tichu": "bin/index.js"
  },
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "start": "pnpm run build && node lib/index.js",
    "build": "pnpm run clean:some && tsc --build",
    "clean:some": "rm -rf ./lib ./docs",
    "clean:all": "rm -rf ./node_modules ./package-lock.json ./lib ./docs",
    "refresh": "pnpm run clean:all && pnpm install",
    "tscov": "tscov --min-coverage 90",
    "tscov:d": "tscov --details",
    "publish-package": "pnpm run build && pnpm publish",
    "docs": "typedoc --out docs ./src",
    "test": "vitest",
    "lint": "eslint src/"
  },
  "keywords": [],
  "author": "",
  "license": "",
  "engines": {
    "node": "24.17.0",
    "pnpm": "11.9.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/ws": "catalog:",
    "typedoc": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@inquirer/prompts": "catalog:",
    "@types/fs-extra": "catalog:",
    "commander": "catalog:",
    "fs-extra": "catalog:",
    "inquirer": "catalog:",
    "kleur": "catalog:",
    "tichu-client-ts-lib": "workspace:",
    "ts-enum-util": "catalog:",
    "tslib": "catalog:",
    "ws": "catalog:"
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended"
    ]
  }
}
